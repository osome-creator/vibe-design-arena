  "conclusions": [
    {
      "topic": "增收不增利",
      "summary": "2025年营收同比增长56.51%至186.95亿元，但归母净利润同比下降31.03%至13.63亿元。核心原因是产品结构调整（中低端产品占比上升）、价格战、原材料成本上涨，以及销售和研发费用的大幅增长。",
      "is_strategic": true,
      "strategic_rationale": "以价换量抢占市场份额，通过高研发投入构建技术护城河，短期牺牲利润换取长期竞争地位。"
    },
    {
      "topic": "财务结构稳健",
      "summary": "2025年末资产负债率仅29.0%，流动比率2.80倍，速动比率1.72倍，财务费用为净收益，几乎无利息偿付压力。未分配利润从45.65亿元升至约86.32亿元。",
      "risk_flag": false
    },
    {
      "topic": "现金流承压",
      "summary": "2025年经营活动现金流净额同比下降55.4%至7.74亿元，自由现金流仅约0.77亿元。主因存货（26.55亿元，+63.5%）和应收账款增加占用了大量营运资金。",
      "risk_flag": true
    },
    {
      "topic": "研发驱动战略",
      "summary": "2025年研发费用14.20亿元（+46.13%），占营收7.59%，高于行业平均水平。研发投入推动了产品线拓宽（扫地机器人、洗地机、割草机器人）和技术普惠。",
      "risk_flag": false
    },
    {
      "topic": "全球化成效显著",
      "summary": "2025年海外收入占比达56%，在德国、北欧、西南欧和北美等市场份额显著提升。全球化布局分散了单一市场风险。",
      "risk_flag": false
    },
    {
      "topic": "毛利率持续回落风险",
      "summary": "毛利率从2024年的50.1%降至2025年的42.3%（-7.8个百分点）。若竞争持续加剧或原材料成本居高不下，毛利率可能进一步下滑。",
      "risk_flag": true
    },
    {
      "topic": "库存大幅增加",
      "summary": "存货从16.24亿元升至26.55亿元（+63.5%），周转天数从约58天升至约105天。原文指出这是为新产品投放和市场扩张进行的备货，但也带来积压和跌价风险。",
      "risk_flag": true
    }
  ],

